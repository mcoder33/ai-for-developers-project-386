import "@typespec/http";
import "@typespec/openapi";
import "@typespec/openapi3";

using TypeSpec.Http;
using TypeSpec.OpenAPI;

@service(#{
  title: "Call Booking API"
})
@info(#{
  version: "0.1.0"
})
@server("http://localhost:3000", "Local development server")
@doc("API contract for a small appointment booking service without authentication.")
namespace CallBooking;

@doc("Default owner profile used by the admin part of the application.")
model Owner {
  @doc("Stable owner identifier.")
  id: string;

  @doc("Public owner display name.")
  @minLength(1)
  name: string;

  @doc("Public owner contact email.")
  @format("email")
  email: string;
}

@doc("Meeting type that can be booked by a guest.")
model EventType {
  @doc("Stable event type identifier.")
  @minLength(1)
  id: string;

  @doc("Human-readable event type title.")
  @minLength(1)
  title: string;

  @doc("Short public description.")
  description: string;

  @doc("Meeting duration in minutes.")
  @minValue(1)
  durationMinutes: int32;
}

@doc("Input for creating an event type.")
model CreateEventTypeRequest {
  @doc("Client-defined stable event type identifier.")
  @minLength(1)
  id: string;

  @doc("Human-readable event type title.")
  @minLength(1)
  title: string;

  @doc("Short public description.")
  description: string;

  @doc("Meeting duration in minutes. The default product scenario uses 30-minute slots.")
  @minValue(1)
  durationMinutes: int32;
}

@doc("A concrete available or occupied time interval for one event type.")
model Slot {
  @doc("Event type this slot belongs to.")
  eventTypeId: string;

  @doc("Slot start time in ISO 8601 format.")
  startsAt: utcDateTime;

  @doc("Slot end time in ISO 8601 format.")
  endsAt: utcDateTime;

  @doc("Whether a guest can book this slot.")
  available: boolean;
}

@doc("Guest data required to create a booking.")
model Guest {
  @doc("Guest display name.")
  @minLength(1)
  name: string;

  @doc("Guest email for meeting communication.")
  @format("email")
  email: string;
}

@doc("A confirmed appointment created by a guest.")
model Booking {
  @doc("Stable booking identifier generated by the server.")
  id: string;

  @doc("Booked event type.")
  eventTypeId: string;

  @doc("Snapshot of event type title at booking time.")
  eventTypeTitle: string;

  @doc("Guest who booked the meeting.")
  guest: Guest;

  @doc("Booking start time in ISO 8601 format.")
  startsAt: utcDateTime;

  @doc("Booking end time in ISO 8601 format.")
  endsAt: utcDateTime;

  @doc("Booking creation time in ISO 8601 format.")
  createdAt: utcDateTime;
}

@doc("Input for creating a booking from a public slot.")
model CreateBookingRequest {
  @doc("Event type selected by the guest.")
  eventTypeId: string;

  @doc("Start time of the selected free slot in ISO 8601 format.")
  startsAt: utcDateTime;

  @doc("Guest name.")
  @minLength(1)
  guestName: string;

  @doc("Guest email.")
  @format("email")
  guestEmail: string;
}

@doc("Machine-readable error code.")
enum ErrorCode {
  validationFailed;
  eventTypeNotFound;
  slotUnavailable;
  bookingWindowExceeded;
  duplicateEventType;
}

@doc("Standard error body.")
model ApiError {
  code: ErrorCode;
  message: string;
}

model CreatedEventTypeResponse {
  @statusCode statusCode: 201;
  @body eventType: EventType;
}

model CreatedBookingResponse {
  @statusCode statusCode: 201;
  @body booking: Booking;
}

model BadRequestResponse {
  @statusCode statusCode: 400;
  @body error: ApiError;
}

model NotFoundResponse {
  @statusCode statusCode: 404;
  @body error: ApiError;
}

model ConflictResponse {
  @statusCode statusCode: 409;
  @body error: ApiError;
}

@tag("Public")
@route("/public")
interface PublicApi {
  @doc("Returns event types visible to guests.")
  @get
  @route("/event-types")
  listPublicEventTypes(): EventType[];

  @doc("Returns one public event type.")
  @get
  @route("/event-types/{eventTypeId}")
  getPublicEventType(@path eventTypeId: string): EventType | NotFoundResponse;

  @doc("Returns 30-minute slots for the selected event type within the next 14 days from the current date. Occupied time is unavailable globally across all event types.")
  @get
  @route("/event-types/{eventTypeId}/slots")
  listSlots(@path eventTypeId: string): Slot[] | NotFoundResponse;

  @doc("Creates a booking for a free slot. The server rejects occupied slots, slots outside the 14-day booking window, and unknown event types.")
  @post
  @route("/bookings")
  createBooking(@body request: CreateBookingRequest): CreatedBookingResponse | BadRequestResponse | NotFoundResponse | ConflictResponse;
}

@tag("Owner")
@route("/owner")
interface OwnerApi {
  @doc("Returns the predefined owner profile.")
  @get
  @route("/profile")
  getOwner(): Owner;

  @doc("Returns all event types managed by the owner.")
  @get
  @route("/event-types")
  listOwnerEventTypes(): EventType[];

  @doc("Creates a new event type managed by the owner.")
  @post
  @route("/event-types")
  createEventType(@body request: CreateEventTypeRequest): CreatedEventTypeResponse | BadRequestResponse | ConflictResponse;

  @doc("Returns upcoming bookings across all event types, ordered by start time ascending.")
  @get
  @route("/bookings/upcoming")
  listUpcomingBookings(): Booking[];
}
